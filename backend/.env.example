# Copy to .env and fill in. Do not commit .env.
# BACKEND_URL is used by the iOS app; set that in Xcode/plist, not here.
# PORT is set by Render; only needed for local run if you want to override.

# PORT=8000

# Optional: Firebase for per-user baseline/session storage.
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
